{
    "expo": {
        "name": "Waiter App",
        "slug": "waiter-app",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "userInterfaceStyle": "light",
        "splash": {
            "image": "./assets/splash.png",
            "resizeMode": "contain",
            "backgroundColor": "#4F46E5"
        },
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.foodapp.waiter"
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/adaptive-icon.png",
                "backgroundColor": "#4F46E5"
            },
            "package": "com.foodapp.waiter"
        },
        "plugins": [
            "expo-router",
            [
                "expo-notifications",
                {
                    "icon": "./assets/notification-icon.png",
                    "color": "#4F46E5",
                    "sounds": []
                }
            ]
        ],
        "scheme": "waiter-app",
        "experiments": {
            "typedRoutes": true
        }
    }
}