// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  password           String
  firstName          String    @map("first_name")
  lastName           String    @map("last_name")
  phone              String?
  role               UserRole  @default(CUSTOMER)
  isActive           Boolean   @default(true) @map("is_active")
  lastLoginAt        DateTime? @map("last_login_at")
  lastLoginIp        String?   @map("last_login_ip")
  emailVerified      Boolean   @default(false) @map("email_verified")
  emailVerifyToken   String?   @map("email_verify_token")
  emailVerifyExpiry  DateTime? @map("email_verify_expiry")
  phoneVerified      Boolean   @default(false) @map("phone_verified")
  phoneVerifyCode    String?   @map("phone_verify_code")
  phoneVerifyExpiry  DateTime? @map("phone_verify_expiry")
  routingRole        String?   @map("routing_role")
  notificationPreference String   @default("email") @map("notification_preference")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  addresses          Address[]
  orders             Order[]
  reviews            Review[]
  loyaltyReward      LoyaltyReward?
  rewardTransactions RewardTransaction[]
  
  // Staff tracking relations
  ordersConfirmed    Order[]     @relation("ConfirmedBy")
  ordersDelivered    Order[]     @relation("DeliveredBy")
  itemsAssigned      OrderItem[] @relation("ItemAssignedTo")
  itemsCompleted     OrderItem[] @relation("ItemCompletedBy")
  staffProfile       StaffProfile?
  
  // Counter/Waiter orders (Pack 5)
  counterOrders      Order[]     @relation("CounterStaff")
  waiterOrders       Order[]     @relation("Waiter")

 reservations        TableReservation[] @relation("ReservationCustomer")
 reservationsConfirmed TableReservation[] @relation("ReservationConfirmedBy")
 reservationsSeated  TableReservation[] @relation("ReservationSeatedBy")
 tableSessions       TableSession[]    @relation("SessionWaiter")
 waiterShifts        WaiterShift[]     @relation("WaiterShifts")

  @@map("users")
}

enum UserRole {
  CUSTOMER
  ADMIN
  STAFF
}

model Address {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  label      String?
  street     String
  number     String
  city       String
  postalCode String   @map("postal_code")
  floor      String?
  notes      String?  @db.Text
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("addresses")
}

model Category {
  id          String     @id @default(uuid())
  name        String
  nameEn      String?    @map("name_en")
  slug        String     @unique
  description String?    @db.Text
  imageUrl    String?    @map("image_url")
  sortOrder   Int        @default(0) @map("sort_order")
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  menuItems   MenuItem[]

  @@map("categories")
}

model MenuItem {
  id          String      @id @default(uuid())
  categoryId  String      @map("category_id")
  name        String
  nameEn      String?     @map("name_en")
  description String?     @db.Text
  price       Decimal     @db.Decimal(10, 2)
  imageUrl    String?     @map("image_url")
  isAvailable Boolean     @default(true) @map("is_available")
  isPopular   Boolean     @default(false) @map("is_popular")
  sortOrder   Int         @default(0) @map("sort_order")
  prepTime    Int         @default(10) @map("prep_time")
  station     String      @default("kitchen")
  calories    Int?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  category    Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]
  images      ProductImage[]

  @@map("menu_items")
}

model ProductImage {
  id          String   @id @default(uuid())
  menuItemId  String   @map("menu_item_id")
  url         String
  sortOrder   Int      @default(0) @map("sort_order")
  isPrimary   Boolean  @default(false) @map("is_primary")
  createdAt   DateTime @default(now()) @map("created_at")

  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model Order {
  id                 String      @id @default(uuid())
  userId             String?     @map("user_id")      // Optional for waiter/counter orders without a customer
  addressId          String?     @map("address_id")  // Optional for counter/waiter orders
  orderNumber        String      @unique @map("order_number")
  orderType          OrderType   @default(DELIVERY) @map("order_type")
  orderSource        String      @default("web") @map("order_source") // web, counter, waiter, kiosk, mobile
  tableNumber        String?     @map("table_number")
  counterStaffId     String?     @map("counter_staff_id")
  waiterId           String?     @map("waiter_id")
  loyaltyPhone       String?     @map("loyalty_phone")
  paymentMethod      String?     @map("payment_method")
  isPaid             Boolean     @default(false) @map("is_paid")
  status             OrderStatus @default(PENDING)
  subtotal           Decimal     @db.Decimal(10, 2)
  deliveryFee        Decimal     @default(0) @map("delivery_fee") @db.Decimal(10, 2)
  discountAmount     Decimal     @default(0) @map("discount_amount") @db.Decimal(10, 2)
  appliedTier        String?     @map("applied_tier")
  totalAmount        Decimal     @map("total_amount") @db.Decimal(10, 2)
  pointsEarned       Int         @default(0) @map("points_earned")
  notes              String?     @db.Text
  deliveryTime       DateTime?   @map("delivery_time")
  completedAt        DateTime?   @map("completed_at")
  cancelledAt        DateTime?   @map("cancelled_at")
  cancellationReason String?     @map("cancellation_reason") @db.Text
  placedAt           DateTime    @default(now()) @map("placed_at")
  confirmedAt        DateTime?   @map("confirmed_at")
  confirmedBy        String?     @map("confirmed_by")
  preparingAt        DateTime?   @map("preparing_at")
  preparingBy        String?     @map("preparing_by")
  readyAt            DateTime?   @map("ready_at")
  readyBy            String?     @map("ready_by")
  outForDeliveryAt   DateTime?   @map("out_for_delivery_at")
  outForDeliveryBy   String?     @map("out_for_delivery_by")
  deliveredAt        DateTime?   @map("delivered_at")
  deliveredBy        String?     @map("delivered_by")
  estimatedTime      Int         @default(15) @map("estimated_time")
  additionalTime     Int         @default(0) @map("additional_time")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  user               User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  address            Address?              @relation(fields: [addressId], references: [id])
  items              OrderItem[]
  payment            Payment?
  reviews            Review[]
  rewardTransactions RewardTransaction[]
  
  // Staff tracking relations
  confirmedByUser    User?                 @relation("ConfirmedBy", fields: [confirmedBy], references: [id])
  deliveredByUser    User?                 @relation("DeliveredBy", fields: [deliveredBy], references: [id])
  counterStaff       User?                 @relation("CounterStaff", fields: [counterStaffId], references: [id])
  waiter             User?                 @relation("Waiter", fields: [waiterId], references: [id])

  tableSessionId String?       @map("table_session_id")
  tableSession   TableSession? @relation(fields: [tableSessionId], references: [id])

  @@index([tableSessionId])

  @@map("orders")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  COMPLETED
  SERVED
}

enum OrderType {
  DELIVERY
  COUNTER
  WAITER
  DINE_IN
}

model OrderItem {
  id          String    @id @default(uuid())
  orderId     String    @map("order_id")
  menuItemId  String    @map("menu_item_id")
  quantity    Int
  price       Decimal   @db.Decimal(10, 2)
  subtotal    Decimal   @db.Decimal(10, 2)
  notes       String?   @db.Text
  station     String?
  prepTime    Int       @default(10) @map("prep_time")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  assignedTo  String?   @map("assigned_to")
  completedBy String?   @map("completed_by")

  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem      MenuItem  @relation(fields: [menuItemId], references: [id])
  assignedUser  User?     @relation("ItemAssignedTo", fields: [assignedTo], references: [id])
  completedUser User?     @relation("ItemCompletedBy", fields: [completedBy], references: [id])

  @@map("order_items")
}

model Payment {
  id            String        @id @default(uuid())
  orderId       String        @unique @map("order_id")
  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  transactionId String?       @map("transaction_id")
  paidAt        DateTime?     @map("paid_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

enum PaymentMethod {
  CASH
  CARD
  ONLINE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Review {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  orderId       String?  @map("order_id")
  rating        Int
  comment       String   @db.Text
  type          String
  status        String   @default("pending")
  adminResponse String?  @db.Text @map("admin_response")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@map("reviews")
}

model LoyaltyReward {
  id             String   @id @default(uuid())
  userId         String   @unique @map("user_id")
  points         Int      @default(0)
  tier           String   @default("bronze")
  lifetimePoints Int      @default(0) @map("lifetime_points")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("loyalty_rewards")
}

model RewardTransaction {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  orderId   String?  @map("order_id")
  points    Int
  type      String
  reason    String
  createdAt DateTime @default(now()) @map("created_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@map("reward_transactions")
}

// ── Enhancement Pack 4: Staff HR ─────────────────────────────────────────

model StaffProfile {
  id             String    @id @default(uuid())
  userId         String    @unique @map("user_id")
  employeeId     String    @unique @map("employee_id")          // e.g. EMP-001
  hiredAt        DateTime  @map("hired_at")
  firedAt        DateTime? @map("fired_at")
  firedReason    String?   @db.Text @map("fired_reason")
  contractType   String    @default("full-time") @map("contract_type")  // full-time | part-time | hourly
  hourlyRate     Decimal?  @db.Decimal(8,2) @map("hourly_rate")
  emergencyName  String?   @map("emergency_name")
  emergencyPhone String?   @map("emergency_phone")
  notes          String?   @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  shifts   WorkShift[]

  @@map("staff_profiles")
}

model WorkShift {
  id          String    @id @default(uuid())
  profileId   String    @map("profile_id")
  dayOfWeek   Int       @map("day_of_week")   // 0=Sun … 6=Sat
  startTime   String    @map("start_time")    // "09:00"
  endTime     String    @map("end_time")      // "17:00"
  station     String?                         // kitchen | barista | …
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

  profile StaffProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("work_shifts")
}

// ── Enhancement Pack 5: Store Settings & Loyalty Tiers ──────────────────────

model StoreSettings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.Text
  category  String   // 'loyalty', 'theme', 'general'
  label     String
  dataType  String   // 'string', 'number', 'boolean', 'json'
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("store_settings")
}

model LoyaltyTier {
  id             String   @id @default(uuid())
  name           String   @unique
  minPoints      Int      @map("min_points")
  maxPoints      Int?     @map("max_points")
  color          String   @default("#6b7280")
  icon           String   @default("🏆")
  discount       Int      @default(0) // percentage discount
  pointsMultiplier Float  @default(1.0) @map("points_multiplier")
  sortOrder      Int      @default(0) @map("sort_order")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("loyalty_tiers")
}

