// Enhancement Pack 6: Waiter & Table Management System
// Add these models to your schema.prisma file
// ═══════════════════════════════════════════════════════════

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum SessionStatus {
  ACTIVE
  COMPLETED
}

enum ShiftStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

model Table {
  id           String       @id @default(uuid())
  tableNumber  String       @unique @map("table_number")
  capacity     Int
  location     String?
  status       TableStatus  @default(AVAILABLE)
  qrCode       String?      @map("qr_code")
  notes        String?      @db.Text
  sortOrder    Int          @default(0) @map("sort_order")
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  reservations TableReservation[]
  sessions     TableSession[]

  @@map("tables")
}

model TableReservation {
  id                  String            @id @default(uuid())
  tableId             String            @map("table_id")
  customerId          String?           @map("customer_id")
  customerName        String            @map("customer_name")
  customerPhone       String            @map("customer_phone")
  customerEmail       String?           @map("customer_email")
  partySize           Int               @map("party_size")
  reservationDate     DateTime          @map("reservation_date") @db.Date
  reservationTime     DateTime          @map("reservation_time") @db.Time
  durationMinutes     Int               @default(90) @map("duration_minutes")
  status              ReservationStatus @default(PENDING)
  specialRequests     String?           @map("special_requests") @db.Text
  notes               String?           @db.Text
  confirmedAt         DateTime?         @map("confirmed_at")
  confirmedBy         String?           @map("confirmed_by")
  seatedAt            DateTime?         @map("seated_at")
  seatedBy            String?           @map("seated_by")
  completedAt         DateTime?         @map("completed_at")
  cancelledAt         DateTime?         @map("cancelled_at")
  cancellationReason  String?           @map("cancellation_reason") @db.Text
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  table               Table             @relation(fields: [tableId], references: [id])
  customer            User?             @relation("ReservationCustomer", fields: [customerId], references: [id])
  confirmedByUser     User?             @relation("ReservationConfirmedBy", fields: [confirmedBy], references: [id])
  seatedByUser        User?             @relation("ReservationSeatedBy", fields: [seatedBy], references: [id])
  sessions            TableSession[]

  @@index([tableId])
  @@index([customerId])
  @@index([reservationDate, reservationTime])
  @@index([status])
  @@index([customerPhone])
  @@map("table_reservations")
}

model TableSession {
  id             String        @id @default(uuid())
  tableId        String        @map("table_id")
  reservationId  String?       @map("reservation_id")
  waiterId       String?       @map("waiter_id")
  customerId     String?
  partySize      Int           @map("party_size")
  startedAt      DateTime      @default(now()) @map("started_at")
  endedAt        DateTime?     @map("ended_at")
  status         SessionStatus @default(ACTIVE)
  totalSpent     Decimal       @default(0.00) @map("total_spent") @db.Decimal(10, 2)
  loyaltyDiscount Int?      
  notes          String?       @db.Text

  table          Table              @relation(fields: [tableId], references: [id])
  reservation    TableReservation?  @relation(fields: [reservationId], references: [id])
  waiter         User?              @relation("SessionWaiter", fields: [waiterId], references: [id])
  customer        Customer? @relation(fields: [customerId], references: [id])  
  orders         Order[]

  @@index([tableId])
  @@index([reservationId])
  @@index([waiterId])
  @@index([status])
  @@index([startedAt])
  @@map("table_sessions")
}

model Customer {
  id              String    @id @default(uuid())
  firstName       String
  lastName        String
  phone           String    @unique
  email           String?
  loyaltyPoints   Int       @default(0)
  discountTier    Int       @default(0)  // 0%, 5%, 10%, etc.
  totalVisits     Int       @default(0)
  createdAt       DateTime  @default(now())
  
  sessions        TableSession[]
  
  @@map("Customer")
}

model WaiterShift {
  id             String      @id @default(uuid())
  waiterId       String      @map("waiter_id")
  shiftDate      DateTime    @map("shift_date") @db.Date
  startTime      DateTime    @map("start_time") @db.Time
  endTime        DateTime    @map("end_time") @db.Time
  actualStart    DateTime?   @map("actual_start")
  actualEnd      DateTime?   @map("actual_end")
  tablesAssigned String?     @map("tables_assigned") @db.Text // JSON array
  status         ShiftStatus @default(SCHEDULED)
  notes          String?     @db.Text
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  waiter         User        @relation("WaiterShifts", fields: [waiterId], references: [id])

  @@index([waiterId])
  @@index([shiftDate])
  @@index([status])
  @@map("waiter_shifts")
}

